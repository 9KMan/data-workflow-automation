# Data & Workflow Automation Platform — Environment Variables

# API Authentication
API_KEY=your-secret-api-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://automation:automation@localhost:5432/automation_db

# n8n Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/test

# ETL Configuration
ETL_MAX_RETRIES=3
ETL_BATCH_SIZE=1000